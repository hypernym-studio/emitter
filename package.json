{
  "name": "@hypernym/emitter",
  "version": "3.0.3",
  "author": "Hypernym Studio",
  "description": "A super simple and lightweight event emitter.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hypernym-studio/emitter.git"
  },
  "homepage": "https://github.com/hypernym-studio/emitter",
  "funding": "https://github.com/sponsors/ivodolenc",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "hyper",
    "hypernym",
    "emit",
    "event",
    "events",
    "emitter",
    "event-emitter",
    "javascript",
    "typescript",
    "manager",
    "esm"
  ],
  "scripts": {
    "dev": "vite playground",
    "build": "hyperbundler",
    "lint": "oxlint",
    "format": "oxfmt",
    "generate:changelog": "hyperchangelog",
    "show-size:min": "wc -c < dist/index.min.js | awk '{printf \"min dist/index.min.js %.2f KB\\n\", $1/1024}'",
    "show-size:gzip": "gzip -c dist/index.min.js | wc -c | awk '{printf \"gzip dist/index.min.js %.2f KB\\n\", $1/1024}'",
    "show-size": "pnpm --silent show-size:min && pnpm --silent show-size:gzip",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@hypernym/bundler": "^0.32.1",
    "@hypernym/changelog": "^0.1.1",
    "@hypernym/oxlint-config": "^0.1.0",
    "@hypernym/tsconfig": "^2.7.0",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.9.3",
    "vite": "8.0.0-beta.16"
  }
}
